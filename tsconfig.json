{
  "compilerOptions": {
    // ── Output ─────────────────────────────────────────────
    "outDir":    "./dist",
    "rootDir":   "./src",

    // ── Target ─────────────────────────────────────────────
    // Node 22 supports all ES2022 features natively.
    "target":    "ES2022",
    "lib":       ["ES2022"],

    // ── Module system ───────────────────────────────────────
   
    "module":           "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop":  true,

    // ── Strictness ──────────────────────────────────────────
    "strict":                           true,
    "noUnusedLocals":                   true,
    "noUnusedParameters":               true,
    "noImplicitReturns":                true,
    "noFallthroughCasesInSwitch":       true,
    "forceConsistentCasingInFileNames": true,

    // ── Extras ──────────────────────────────────────────────
    "resolveJsonModule":  true,
    "skipLibCheck":       true,
    "declaration":        true,
    "declarationMap":     true,
    "sourceMap":          true,

    // ── Path aliases ──
    "baseUrl": ".",
    "paths": {
      "@core/*":    ["src/core/*"],
      "@utils/*":   ["src/utils/*"],
      "@agents/*":  ["agents/*"],
      "@adapters/*":["adapters/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "www",
    "**/*.test.ts",
    "**/*.spec.ts",
    "custom-plugins/**",
    "scripts/**"
  ],
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  }
}
