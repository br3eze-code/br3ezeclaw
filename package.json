{
  "name": "br3eze-code",
  "version": "2026.4.18",
  "description": "AgentOS \u2014 Autonomous network intelligence platform for MikroTik RouterOS with AI integration",
  "main": "src/core/gateway.js",
  "bin": {
    "agentos": "./bin/agentos.js",
    "agentos-esm": "./agentos.mjs"
  },
  "scripts": {
    "start": "node bin/agentos.js gateway",
    "start:modern": "node agentos.mjs",
    "dev": "nodemon bin/agentos.js --dev",
    "setup": "node bin/agentos.js onboard",
    "security:audit": "npm audit && node scripts/security-check.js",
    "test": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "build": "tsc --project tsconfig.json",
    "build:android": "cordova build android",
    "build:ios": "cordova build ios",
    "db:migrate": "node scripts/migrate-vouchers.js",
    "build:check": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/br3eze-code/br3eze-code.git"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mikrotik",
    "routeros",
    "hotspot",
    "network-management",
    "telegram-bot",
    "ai-agent",
    "gemini",
    "agentos",
     "ai",
    "automation",
    "wifi",
    "captive-portal",
    "voucher",
    "wifi-billing",
    "starlink"
  ],
  "author": "MZACANA / Br3eze Africa",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.8.0",
    "boxen": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "*",
    "express-rate-limit": "*",
    "express-validator": "^7.3.2",
    "js-yaml": "^4.1.0",
    "firebase": "*",
    "firebase-admin": "*",
    "helmet": "^8.1.0",
    "inquirer": "^9.2.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pino": "^8.17.0",
    "pino-pretty": "^11.2.0",
    "qrcode-terminal": "^0.12.0",
    "rate-limiter-flexible": "^5.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "ora": "^8.0.0",
    "pm2": "^6.0.14",
    "speakeasy": "^2.0.0",
    "twilio": "^5.0.0",
    "nodemailer": "^6.9.7",
    "ioredis": "^5.3.2",
    "openai": "^4.52.0",
    "compression": "^1.7.4",
    "qrcode": "^1.5.4",
    "routeros-client": "^1.1.1",
    "undici": "^6.24.0",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "uuid": "^9.0.1",
    "xterm": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "cordova": "^13.0.0",
    "cordova-android": "^15.0.0",
    "cordova-browser": "^7.0.0",
    "nodemon": "^3.1.7",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "*",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.3.3",
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.22.15",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "jest": "^29.7.0"
  },
  "cordova": {
    "platforms": [
      "android",
      "ios",
      "browser"
    ]
  },
  "optionalDependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.4",
    "mastercard-api-core": "^1.5.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/br3eze-code"
  },
"jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2024": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "plugin:security/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2024,
      "sourceType": "commonjs"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-console": "off",
      "security/detect-object-injection": "warn",
      "node/no-unpublished-require": "off"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "modulePaths": [
      "/tmp/jest-deps/node_modules"
    ],
    "collectCoverageFrom": [
      "src/core/*.js",
      "src/utils/*.js",
      "adapters/*.js",
      "agents/*.js",
      "tools/system/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000
  }
}
