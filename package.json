{
	"name": "br3eze-code",
	"version": "2026.5.66",
	"description": "AgentOS — Network Intelligence Operating System for MikroTik via AI",
	"main": "src/core/gateway.js",
	"bin": {
		"agentos": "./bin/agentos.js",
		"agentos-esm": "./agentos.mjs"
	},
	"scripts": {
		"start": "node bin/agentos.js gateway",
		"start:modern": "node agentos.mjs",
		"dev": "nodemon bin/agentos.js --dev",
		"setup": "node bin/agentos.js onboard",
		"security:audit": "npm audit && node scripts/security-check.js",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"src/**/*.js\"",
		"build": "tsc --project tsconfig.json",
		"build:android": "cordova build android",
		"build:ios": "cordova build ios",
		"db:migrate": "node scripts/migrate-vouchers.js",
		"build:check": "tsc --noEmit",
		"postinstall": "node scripts/postinstall.js",
		"preuninstall": "node scripts/preuninstall.js",
		"clean": "rm -rf dist"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/br3eze-code/br3eze-code.git"
	},
	"files": [
		"bin/",
		"src/",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"mikrotik",
		"routeros",
		"hotspot",
		"network-management",
		"telegram-bot",
		"ai-agent",
		"gemini",
		"agentos",
		"wifi-billing",
		"starlink"
	],
	"author": "MZACANA / Br3eze Africa",
	"license": "Apache-2.0",
	"type": "commonjs",
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.24.0",
		"@aws-sdk/client-ec2": "^3.1035.0",
		"@aws-sdk/client-s3": "^3.1035.0",
		"@clack/prompts": "^1.3.0",
		"@google-cloud/compute": "^6.9.0",
		"@google-cloud/vertexai": "^1.12.0",
		"@google/generative-ai": "^0.24.1",
		"@kubernetes/client-node": "^1.4.0",
		"@octokit/auth-app": "^8.2.0",
		"@octokit/rest": "^22.0.1",
		"axios": "^1.13.2",
		"bcryptjs": "^2.4.3",
		"better-sqlite3": "^12.8.0",
		"boxen": "^7.1.1",
		"chalk": "^4.1.2",
		"commander": "^12.1.0",
		"compression": "^1.7.4",
		"cors": "^2.8.6",
		"debug": "^4.4.3",
		"digest-fetch": "^3.1.1",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.1",
		"express": "*",
		"express-rate-limit": "*",
		"express-validator": "^7.3.2",
		"firebase": "*",
		"firebase-admin": "*",
		"form-data": "^4.0.5",
		"google-auth-library": "^10.6.2",
		"helmet": "^8.1.0",
		"hpp": "^0.2.3",
		"inquirer": "^8.2.7",
		"ioredis": "^5.3.2",
		"joi": "^18.1.2",
		"js-yaml": "^4.1.0",
		"jsonwebtoken": "^9.0.2",
		"morgan": "^1.10.0",
		"node-cache": "^5.1.2",
		"node-pagerduty": "^1.3.6",
		"node-telegram-bot-api": "^0.67.0",
		"node-thermal-printer": "^4.6.0",
		"nodemailer": "^6.9.7",
		"openai": "^4.52.0",
		"ora": "^5.4.1",
		"passport": "^0.7.0",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.1",
		"pdf-lib": "1.17.1",
		"pdf-parse": "^2.4.5",
		"pino": "^8.17.0",
		"pm2": "^6.0.14",
		"prom-client": "^15.1.3",
		"puppeteer-core": "24.42.0",
		"python-shell": "^5.0.0",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"rate-limiter-flexible": "^5.0.0",
		"routeros-client": "^1.1.1",
		"serialport": "^13.0.0",
		"speakeasy": "^2.0.0",
		"ssh2": "^1.17.0",
		"twilio": "^5.0.0",
		"undici": "^6.24.0",
		"uuid": "^9.0.1",
		"winston": "^3.19.0",
		"ws": "^8.20.0",
		"xml2js": "^0.6.2",
		"xss-clean": "^0.1.4",
		"xterm": "^5.3.0",
		"zod": "^3.22.0"
	},
	"devDependencies": {
		"@babel/core": "^7.23.3",
		"@babel/preset-env": "^7.23.3",
		"@babel/preset-react": "^7.22.15",
		"@testing-library/jest-dom": "^6.1.4",
		"@testing-library/react": "^14.1.0",
		"@testing-library/user-event": "^14.5.1",
		"@types/jest": "^29.5.12",
		"@types/node": "^20.10.5",
		"@types/react": "^18.2.46",
		"@types/react-dom": "^18.2.18",
		"@types/uuid": "^9.0.7",
		"@types/ws": "^8.5.10",
		"cordova": "^13.0.0",
		"cordova-android": "^15.0.0",
		"cordova-browser": "^7.0.0",
		"eslint": "8.56.0",
		"eslint-config-prettier": "*",
		"eslint-plugin-prettier": "*",
		"jest": "^29.7.0",
		"nodemon": "^3.1.11",
		"prettier": "^3.2.5",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.1",
		"ts-node": "^10.9.1",
		"typescript": "^5.3.3"
	},
	"cordova": {
		"platforms": [
			"android",
			"ios",
			"browser"
		]
	},
	"optionalDependencies": {
		"@whiskeysockets/baileys": "^7.0.0-rc.9",
		"mastercard-api-core": "^1.5.0"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/br3eze-code"
	},
	"jest": {
		"testEnvironment": "node",
		"testMatch": [
			"**/tests/**/*.test.js"
		],
		"testPathIgnorePatterns": [
			"/node_modules/"
		],
		"modulePaths": [
			"/tmp/jest-deps/node_modules"
		],
		"collectCoverageFrom": [
			"src/core/*.js",
			"src/utils/*.js",
			"adapters/*.js",
			"agents/*.js",
			"tools/system/*.js"
		],
		"coverageReporters": [
			"text",
			"lcov"
		],
		"testTimeout": 15000
	}
}
