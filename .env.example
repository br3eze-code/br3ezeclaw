# ═══════════════════════════════════════════════════════════════════
# AgentOS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

DRIVER_BLENDER_ENABLED=true
BLENDER_SD_API=http://localhost:7860/sdapi/v1/txt2img # Automatic1111 or ComfyUI

DRIVER_DAHUA_ENABLED=true
# Per-device creds better in Vault. For simple setup:
DRIVER_DAHUA_USER=admin
DRIVER_DAHUA_PASSWORD=use_gcp_secret_manager_in_prod

DRIVER_DATADOG_ENABLED=true
DRIVER_DATADOG_API_KEY=...
DRIVER_DATADOG_APP_KEY=...


DRIVER_GCP_ENABLED=true
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

DRIVER_PAGERDUTY_ENABLED=true
DRIVER_PAGERDUTY_API_TOKEN= # REST API v2 token with incidents:write

DRIVER_MACOS_ENABLED=true
DRIVER_MACOS_USER=agentos
DRIVER_MACOS_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
DRIVER_MACOS_SUDO_PASSWORD= # only if you need sudo and don't use NOPASSWD

DRIVER_SLACK_ENABLED=true
DRIVER_SLACK_BOT_TOKEN=xoxb-...
DRIVER_SLACK_SIGNING_SECRET=...
DRIVER_SLACK_APP_TOKEN=xapp-... # for Socket Mode

DRIVER_LINUX_ENABLED=true
DRIVER_LINUX_USER=agentos
DRIVER_LINUX_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
DRIVER_LINUX_SUDO_PASSWORD= # or use NOPASSWD in sudoers

# ── MikroTik Router ─────────────────────────────────────────────────
MIKROTIK_IP=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=
MIKROTIK_PORT=8728

# ── Telegram Bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
WHATSAPP_ENABLED=true

# ── AI Providers (set whichever you use) ────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Gateway ─────────────────────────────────────────────────────────
AGENTOS_GATEWAY_TOKEN=          # auto-generated if blank
AGENTOS_DASHBOARD_URL=http://localhost:3000

# ── Voucher / Billing ───────────────────────────────────────────────
# Prefix prepended to all generated voucher codes (e.g. VCH, NET, ISP)
VOUCHER_PREFIX=VCH
# Comma-separated plan names — must match MikroTik hotspot profile names
VOUCHER_PLANS=default,1day,7day,30day

# ── Brand / Operator Identity ───────────────────────────────────────
# Displayed in receipts, Mastercard A2A metadata, and the AI agent greeting
BRAND_SERVICE_NAME=AgentOS Hotspot
BRAND_RECIPIENT_NAME=AgentOS

# ── Mastercard A2A Commerce (optional) ─────────────────────────────
MASTERCARD_CONSUMER_KEY=
MASTERCARD_KEY_ALIAS=
MASTERCARD_KEY_PASSWORD=
MASTERCARD_P12_PATH=

# ── Firebase (optional — leave blank to use local SQLite) ───────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Profile ─────────────────────────────────────────────────────────
# 'default' uses ~/.agentos; any other value uses ~/.agentos-<profile>
AGENTOS_PROFILE=default
LOG_LEVEL=info
JWT_SECRET=your-secret-key-here

# AI Providers (Configure at least one)
# Primary provider: gemini, claude, openai, ollama
PRIMARY_PROVIDER=gemini
FALLBACK_PROVIDERS=claude,ollama


# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (Local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=

# WhatsApp (Baileys)
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_NAME=agentos-session

# Discord (Optional)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Slack (Optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Gateway Settings
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
HEARTBEAT_INTERVAL=1800000

# Security
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# MCP (Model Context Protocol)
MCP_ENABLED=true
MCP_SERVER_PORT=3001

# Session & Memory
SESSION_MODE=isolated
MEMORY_BASE_PATH=./data/sessions
SKILLS_PATH=./src/skills
